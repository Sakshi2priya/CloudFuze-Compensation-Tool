# Copy this file to `.env` and fill in values. Do not commit `.env`.
# HubSpot: Settings → Integrations → Private Apps → your app → Access token

HUBSPOT_ACCESS_TOKEN=pat-na1-your-private-app-token-here

# Default year/quarter for HubSpot import (Close date). UI overrides when you pick year & quarter.
# HUBSPOT_DEAL_YEAR=2025
# HUBSPOT_DEAL_QUARTER=4

# HubSpot deal property **internal name** for payment status (Settings → Properties → Deals).
# Works with dropdown/select fields; use the property’s API name (e.g. payment_status, cf_payment_status).
# Default: payment_status. Set to empty or none to skip requesting it (imports as UNPAID).
# Private App scopes: read deals (e.g. crm.objects.deals.read) plus **crm.schemas.deals.read** to load dropdown options in the UI.
# To sync **Sales Goals / Forecast** targets (goal_targets) into User Management: add Goals read, e.g. **crm.objects.goals.read**.
# HUBSPOT_PAYMENT_STATUS_PROPERTY=payment_status

# ----- AI Assistant (sidebar) -----
# Anthropic API key for the in-app Q&A assistant. Get one at https://console.anthropic.com → API keys.
# Without this, the Assistant falls back to rule-based answers (limited coverage).
# ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model (default: claude-haiku-4-5-20251001 — fast & cheap; switch to claude-sonnet-4-6 for harder reasoning).
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
#
# The inline pinned-data chat assistants (on SMB Q1, AM Q1, SMB monthly, AM monthly pages)
# default to claude-sonnet-4-6 for accurate compensation math. Override here if desired.
# ANTHROPIC_PINNED_CHAT_MODEL=claude-sonnet-4-6
